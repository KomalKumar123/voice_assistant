# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: ollama | openrouter | openai | gemini | groq | deepseek | together | anthropic
LLM_PROVIDER=ollama
MODEL_NAME=qwen3:14b
HOST=http://localhost:11434

# API key — only needed for cloud providers (openrouter, openai, gemini, groq, deepseek, together, anthropic)
API_KEY=bf66ba11e05c45518210578e50120c43.eSdqou51pk0pf2haPpGRhNSd

# ── Qwen3 Thinking Mode ───────────────────────────────────────────────────────
# ENABLE_THINKING=true  → enables full chain-of-thought (slow: minutes per call)
# ENABLE_THINKING=false → disables thinking via /no_think suffix (fast: seconds)
ENABLE_THINKING=false

# Max tokens the model may generate per LLM call.
# 1024 is fast. Increase to 2048+ for complex code generation if answers truncate.
NUM_PREDICT=1024

# ── Whisper STT ───────────────────────────────────────────────────────────────
# Supported sizes: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base
WHISPER_COMPUTE_TYPE=int8

